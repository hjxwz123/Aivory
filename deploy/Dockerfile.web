# syntax=docker/dockerfile:1
#
# Aurelia web image: builds the Vite SPA and serves it from nginx, reverse-
# proxying /api to the api service. Build context is the repository root.
#
#   docker build -f deploy/Dockerfile.web -t aurelia-web:latest .
#
# The SPA targets a same-origin /api (src/api/client.ts), so there is no
# build-time backend URL — nginx routes /api to the api container.

FROM node:20-bookworm-slim AS build
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
# Copy only what the build needs (server/ and node_modules are excluded).
COPY index.html vite.config.ts tsconfig.json tsconfig.app.json tsconfig.node.json ./
COPY tailwind.config.ts postcss.config.js eslint.config.js ./
COPY src ./src
COPY public ./public
RUN npm run build

FROM nginx:1.27-alpine AS runtime
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
HEALTHCHECK --interval=15s --timeout=3s --start-period=5s --retries=5 \
    CMD wget -qO- http://127.0.0.1/ >/dev/null 2>&1 || exit 1
